#include <Wire.h>
#include <Adafruit_DPS310.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <time.h>


/* ================= WIFI & FIREBASE CONFIGURATION ================= */
const char* WIFI_SSID     = "H";
const char* WIFI_PASSWORD = "12345678";
const char* DATABASE_URL  = "https://autowesta-f5007-default-rtdb.firebaseio.com/weather_logs.json";
const char* FIREBASE_API_KEY = "AIzaSyDxEzOn8z7-8HrS94hfHS1sz2aPQem0v38";


/* ================= TIME CONFIGURATION ================= */
const int GMT_OFFSET_SEC = 19800;  // GMT+5:30 India


/* ================= CONSTANTS ================= */
const unsigned long UPLOAD_INTERVAL = 10000;


/* ================= MQ135 ================= */
const int MQ135pin = 34;


/* ================= THRESHOLDS ================= */
const float CO2_THRESHOLD     = 1000.0;
const float CO_THRESHOLD      = 10.0;
const float METHANE_THRESHOLD = 1000.0;
const float AMMONIA_THRESHOLD = 25.0;


/* ================= DPS310 ================= */
Adafruit_DPS310 dps;
bool dpsAvailable = false;


/* ================= WEATHER DATA ================= */
struct WeatherData {
  float windSpeed;
  String windDirection;
  float tempC;
  float tempF;
  float humidity;
  float rainfall;
  float pressure;
  float altitude;
  float co2;
  float co;
  float methane;
  float ammonia;
  String airQuality;
};


WeatherData currentWeather;
unsigned long lastUploadTime = 0;
bool dataReady = false;


/* ================= SETUP ================= */
void setup() {
  Serial.begin(9600);
  delay(2000);


  Serial.println("\n=== AutoWesta ESP32 Starting ===");


  Serial2.begin(9600, SERIAL_8N1, 16, 17);
  Serial.println("Serial2 initialized");


  Wire.begin(21, 22);
  Serial.println("I2C initialized");


  pinMode(MQ135pin, INPUT);
  Serial.println("MQ135 initialized on GPIO 34");


  Serial.println("Initializing DPS310...");
  if (!dps.begin_I2C()) {
    Serial.println("WARNING: DPS310 not found!");
    dpsAvailable = false;
  } else {
    Serial.println("DPS310 Ready!");
    dps.configurePressure(DPS310_64HZ, DPS310_64SAMPLES);
    dpsAvailable = true;
  }


  Serial.print("Connecting to WiFi");
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int wifiAttempts = 0;
  while (WiFi.status() != WL_CONNECTED && wifiAttempts < 20) {
    delay(500);
    Serial.print(".");
    wifiAttempts++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi Connected!");
    Serial.print("IP: "); Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nWiFi Failed!");
  }


  configTime(GMT_OFFSET_SEC, 0, "pool.ntp.org");
  Serial.println("Time sync configured");
  Serial.println("=== System Ready ===\n");
}


/* ================= READ MQ135 ================= */
void readMQ135() {
  int rawValue = analogRead(MQ135pin);
  float voltage    = rawValue / 1024.0 * 5.0;
  float resistance = (5.0 - voltage) / voltage;


  currentWeather.co2     = 1.0 / (0.03588 * pow(resistance, 1.336));
  currentWeather.methane = currentWeather.co2 / 2.7;
  currentWeather.co      = (currentWeather.co2 / 2.2) * 0.085;
  currentWeather.ammonia = (currentWeather.co2 / 3.6) * 0.18;


  // Determine air quality
  if (currentWeather.co2     > CO2_THRESHOLD     ||
      currentWeather.co      > CO_THRESHOLD      ||
      currentWeather.methane > METHANE_THRESHOLD  ||
      currentWeather.ammonia > AMMONIA_THRESHOLD) {
    currentWeather.airQuality = "BAD";
  } else {
    currentWeather.airQuality = "GOOD";
  }
}


/* ================= LOOP ================= */
void loop() {
  static unsigned long lastHeartbeat = 0;
  static unsigned long dataCount = 0;


  if (millis() - lastHeartbeat > 10000) {
    Serial.print("[Heartbeat] Packets: "); Serial.print(dataCount);
    Serial.print(" | Uptime: "); Serial.print(millis() / 1000); Serial.println("s");
    lastHeartbeat = millis();
  }


  // Read MQ135
  readMQ135();


  // Read DPS310 - pressure only
  if (dpsAvailable) {
    sensors_event_t temp_event, pressure_event;
    if (dps.pressureAvailable()) {
      dps.getEvents(&temp_event, &pressure_event);
      currentWeather.pressure = pressure_event.pressure;
      currentWeather.altitude = 44330.0 * (1.0 - pow(currentWeather.pressure / 1013.25, 0.1903));
    }
  }


  // Receive data from Arduino
  if (Serial2.available()) {
    String data = Serial2.readStringUntil('\n');
    data.trim();
    if (data.length() > 0) {
      Serial.print("[Arduino] "); Serial.println(data);
      parseWeatherData(data);
      displayWeatherData();
      dataCount++;
      dataReady = true;
    }
  }


  // Upload to Firebase every 10 seconds
  if (dataReady && (millis() - lastUploadTime >= UPLOAD_INTERVAL)) {
    sendToFirebase();
    lastUploadTime = millis();
    dataReady = false;
  }
}


/* ================= PARSE ARDUINO DATA ================= */
void parseWeatherData(String data) {
  int commaPos;
  String values[6];
  for (int i = 0; i < 6; i++) {
    commaPos = data.indexOf(',');
    if (commaPos != -1) {
      values[i] = data.substring(0, commaPos);
      data = data.substring(commaPos + 1);
    } else {
      values[i] = data;
    }
  }
  currentWeather.windSpeed     = values[0].toFloat();
  currentWeather.windDirection = values[1];
  currentWeather.tempC         = values[2].toFloat();
  currentWeather.tempF         = values[3].toFloat();
  currentWeather.humidity      = values[4].toFloat();
  currentWeather.rainfall      = values[5].toFloat();
}


/* ================= DISPLAY DATA ================= */
void displayWeatherData() {
  Serial.println("\n╔════════════════════════════════════╗");
  Serial.println("║        COMPLETE WEATHER DATA       ║");
  Serial.println("╚════════════════════════════════════╝");


  Serial.print("┃ Wind Speed     : "); Serial.print(currentWeather.windSpeed, 2);   Serial.println(" m/s");
  Serial.print("┃ Wind Direction : "); Serial.println(currentWeather.windDirection);
  Serial.print("┃ Temperature    : "); Serial.print(currentWeather.tempC, 1);        Serial.print("°C ("); Serial.print(currentWeather.tempF, 1); Serial.println("°F)");
  Serial.print("┃ Humidity       : "); Serial.print(currentWeather.humidity, 1);     Serial.println("%");
  Serial.print("┃ Rainfall       : "); Serial.print(currentWeather.rainfall, 2);     Serial.println(" mm");


  if (dpsAvailable) {
    Serial.println("┃ --- Barometer ---");
    Serial.print("┃ Pressure       : "); Serial.print(currentWeather.pressure, 2);  Serial.println(" hPa");
    Serial.print("┃ Altitude       : "); Serial.print(currentWeather.altitude, 1);  Serial.println(" m");
  }


  Serial.println("┃ --- Air Quality ---");
  Serial.print("┃ CO2            : "); Serial.print(currentWeather.co2, 2);     Serial.println(" ppm");
  Serial.print("┃ CO             : "); Serial.print(currentWeather.co, 2);      Serial.println(" ppm");
  Serial.print("┃ Methane CH4    : "); Serial.print(currentWeather.methane, 2); Serial.println(" ppm");
  Serial.print("┃ Ammonia NH3    : "); Serial.print(currentWeather.ammonia, 2); Serial.println(" ppm");
  Serial.print("┃ Air Status     : "); Serial.println(currentWeather.airQuality);
  Serial.println("════════════════════════════════════\n");
}


/* ================= FIREBASE UPLOAD ================= */
void sendToFirebase() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("⚠ Firebase: WiFi not connected");
    return;
  }


  HTTPClient http;
  String urlWithAuth = String(DATABASE_URL) + "?auth=" + String(FIREBASE_API_KEY);
  http.begin(urlWithAuth);
  http.addHeader("Content-Type", "application/json");


  String payload = "{";
  payload += "\"windSpeed\":"       + String(currentWeather.windSpeed, 2)   + ",";
  payload += "\"windDirection\":\"" + currentWeather.windDirection           + "\",";
  payload += "\"tempC\":"           + String(currentWeather.tempC, 1)        + ",";
  payload += "\"tempF\":"           + String(currentWeather.tempF, 1)        + ",";
  payload += "\"humidity\":"        + String(currentWeather.humidity, 1)     + ",";
  payload += "\"rainfall\":"        + String(currentWeather.rainfall, 2)     + ",";
  payload += "\"co2\":"             + String(currentWeather.co2, 2)          + ",";
  payload += "\"co\":"              + String(currentWeather.co, 2)           + ",";
  payload += "\"methane\":"         + String(currentWeather.methane, 2)      + ",";
  payload += "\"ammonia\":"         + String(currentWeather.ammonia, 2)      + ",";
  payload += "\"airQuality\":\"" + currentWeather.airQuality                 + "\",";


  if (dpsAvailable) {
    payload += "\"pressure\":"  + String(currentWeather.pressure, 2) + ",";
    payload += "\"altitude\":"  + String(currentWeather.altitude, 1) + ",";
  }


  payload += "\"timestamp\":{\".sv\":\"timestamp\"}";
  payload += "}";


  Serial.println("┌─────────────────────────────────┐");
  Serial.println("│  UPLOADING TO FIREBASE          │");
  Serial.println("└─────────────────────────────────┘");


  int httpCode = http.POST(payload);
  if (httpCode == 200) {
    Serial.println("✓ Firebase: Upload SUCCESS");
  } else {
    Serial.print("✗ Firebase: Failed, Code: "); Serial.println(httpCode);
  }


  http.end();
  printTimestamp();
}


/* ================= TIMESTAMP ================= */
void printTimestamp() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo)) {
    char timestamp[25];
    strftime(timestamp, sizeof(timestamp), "%d-%m-%Y %H:%M:%S", &timeinfo);
    Serial.print("Upload Time: "); Serial.println(timestamp);
  } else {
    Serial.println("Upload Time: Not synced");
  }
}
